# SoulSaying Configuration
# Copy this file to config.env and fill in your values.

# ─── SiliconFlow TTS (required) ───
# Get your API key at https://siliconflow.cn (free tier available)
SILICONFLOW_API_KEY=""

# Voice URI — run clone_voice.sh to get this, or use a built-in voice
# Cloned: "speech:my_voice:account_id:voice_id"
# Built-in: "FunAudioLLM/CosyVoice2-0.5B:bella"
VOICE_URI=""

# TTS Model — IndexTTS-2 recommended for cloned voices
# Options: "IndexTeam/IndexTTS-2" or "FunAudioLLM/CosyVoice2-0.5B"
TTS_MODEL="IndexTeam/IndexTTS-2"

# ─── Default Platform ───
# Which platform speak.sh sends to by default
# Options: feishu, telegram, discord, whatsapp, local
PLATFORM="feishu"

# ─── Feishu / Lark ───
# Create a bot at https://open.feishu.cn/app (or https://open.larksuite.com/app)
# Required permissions: im:message:create, im:file
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
FEISHU_OPEN_ID=""

# ─── Telegram ───
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── Discord ───
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=""
DISCORD_CHANNEL_ID=""

# ─── WhatsApp Business ───
# Set up at https://developers.facebook.com (WhatsApp Business Cloud API)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_TO=""
